#!/bin/bash
APP="${1:-Firefox}"

WIN_ID=$(yabai -m query --windows | jq -r --arg app "$APP" \
  'map(select(.app == $app and ."is-minimized" == false)) | .[0].id // empty')

wait_for_focus() {
  local expected="$1"
  for _ in $(seq 1 10); do
    local current
    current=$(yabai -m query --windows --window 2>/dev/null | jq -r '.id // empty')
    [ "$current" = "$expected" ] && return 0
    sleep 0.05
  done
  return 1
}

cliclick_with_fallback() {
  ~/bin/cliclick_focus
  (sleep 0.3 && ~/bin/cliclick_focus) &
}

if [ -n "$WIN_ID" ]; then
  FOCUSED_ID=$(yabai -m query --windows --window 2>/dev/null | jq -r '.id // empty')
  if [ "$WIN_ID" != "$FOCUSED_ID" ]; then
    yabai -m window --focus "$WIN_ID"
    wait_for_focus "$WIN_ID"
  fi
  cliclick_with_fallback
else
  yabai -m signal --add \
    event=window_created \
    app="$APP" \
    label="open_or_focus_once" \
    action='yabai -m signal --remove open_or_focus_once; \
            yabai -m window --focus $YABAI_WINDOW_ID; \
            $HOME/bin/cliclick_focus'
  open -a "$APP"
fi

