#!/bin/bash

# IP of your Elgato Key Light
LIGHT_IP="192.168.178.42"

# Ask user for brightness percentage
read -p "Enter brightness percentage (0-100): " BRIGHTNESS

# Validate input
if ! [[ "$BRIGHTNESS" =~ ^[0-9]+$ ]] || [ "$BRIGHTNESS" -lt 0 ] || [ "$BRIGHTNESS" -gt 100 ]; then
    echo "Please enter a valid number between 0 and 100."
    exit 1
fi

# Send the brightness command, suppress all output
curl -s -X PUT "http://$LIGHT_IP:9123/elgato/lights" \
    -d "{\"lights\":[{\"brightness\":$BRIGHTNESS,\"on\":1}]}" \
    -H "Content-Type: application/json" >/dev/null 2>&1

